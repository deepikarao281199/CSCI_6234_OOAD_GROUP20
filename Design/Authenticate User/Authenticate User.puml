@startuml
title Sequence Diagram - Authenticate User (Login)
skinparam shadowing false
skinparam linetype ortho

actor UserActor as "User"
boundary LoginView
control AuthController
control AuthService
entity Credentials
entity User
database UserRepository

UserActor -> LoginView : enterUsernamePassword()
LoginView -> AuthController : submitLogin(username, password)

AuthController -> AuthService : authenticate(username, password)

AuthService -> Credentials : create(username, password)
AuthService -> Credentials : validateFormat()

alt Invalid format
  AuthService --> AuthController : authFailed("Validation error")
  AuthController --> LoginView : showValidationErrors()
else Format OK
  AuthService -> UserRepository : findByUsername(username)
  UserRepository --> AuthService : userRecord (User?)

  alt User not found
    AuthService --> AuthController : authFailed("User not found")
    AuthController --> LoginView : showInvalidCredentials()
  else User found
    AuthService -> User : verifyPassword(password)
    alt Password incorrect
      AuthService --> AuthController : authFailed("Invalid credentials")
      AuthController --> LoginView : showInvalidCredentials()
    else Password correct
      AuthService -> AuthService : createSessionToken(user)
      AuthService --> AuthController : authSuccess(token)
      AuthController --> LoginView : showHome()
    end
  end
end

@enduml