@startuml
title Sequence Diagram - Manage Profile & Preferences
skinparam shadowing false
skinparam linetype ortho

actor UserActor as "User"
boundary ProfileView
control ProfileController
control ProfileService
entity User
entity Preference
database UserRepository

UserActor -> ProfileView : editProfileAndPreferences()
ProfileView -> ProfileController : saveProfileChanges(userId, changes, prefChanges)

ProfileController -> ProfileService : updateProfile(userId, changes, prefChanges)

ProfileService -> UserRepository : loadUser(userId)
UserRepository --> ProfileService : user (User)

ProfileService -> User : applyProfileChanges(changes)
ProfileService -> Preference : applyPreferenceChanges(user, prefChanges)

ProfileService -> UserRepository : saveUser(user)
ProfileService --> ProfileController : updatedUser(user)

ProfileController --> ProfileView : showUpdatedProfile(user)

@enduml